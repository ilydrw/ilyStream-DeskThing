{
  "name": "ilystream-deskthing",
  "version": "0.0.9",
  "description": "Spotify Car Thing client for ilyStream — soundboard and stream-deck remote",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node build.js",
    "build:client": "vite build --outDir dist/client",
    "build:server": "tsc -p tsconfig.server.json",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "@deskthing/client": "^0.11.2",
    "@deskthing/server": "^0.11.6"
  },
  "devDependencies": {
    "@deskthing/cli": "^0.11.15",
    "@deskthing/types": "^0.11.18",
    "@types/node": "^25.3.3",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "adm-zip": "^0.5.16",
    "esbuild": "^0.27.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.0",
    "vite": "^6.4.2",
    "vite-plugin-css-injected-by-js": "^4.0.1"
  },
  "overrides": {
    "tsm": {
      "esbuild": "^0.25.12"
    }
  }
}
